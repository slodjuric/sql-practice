DB_HOST=localhost
DB_PORT=5432
DB_NAME=sql_practice
DB_USER=your_pg_username
DB_PASSWORD=

# Optional — connection pool tuning (see backend/src/db.js). Values shown are
# the defaults used when unset. Check Answer acquires two dedicated
# connections per request (one for the student's query, one for the trusted
# solution), so DB_POOL_MAX is the main lever if concurrent Check Answer
# traffic starts queuing; DB_CONNECTION_TIMEOUT_MS bounds how long a request
# waits for a pool slot before failing with a controlled error instead of
# hanging.
# DB_POOL_MAX=10
# DB_CONNECTION_TIMEOUT_MS=5000
# DB_IDLE_TIMEOUT_MS=30000

PORT=3001

# Required — session cookie signing secret. Generate a real random value for
# your local .env; the server refuses to start without one.
SESSION_SECRET=change-me

# Optional — force /api-docs (Swagger UI) on ("true") or off ("false")
# regardless of NODE_ENV. Default: enabled unless NODE_ENV=production.
# ENABLE_API_DOCS=true
