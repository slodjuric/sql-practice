DB_HOST=localhost
DB_PORT=5432
DB_NAME=sql_practice
DB_USER=your_pg_username
DB_PASSWORD=
PORT=3001

# Required — session cookie signing secret. Generate a real random value for
# your local .env; the server refuses to start without one.
SESSION_SECRET=change-me

# Optional — force /api-docs (Swagger UI) on ("true") or off ("false")
# regardless of NODE_ENV. Default: enabled unless NODE_ENV=production.
# ENABLE_API_DOCS=true
